# Percy Dashboard — Environment Variables
# Copy this to .env and fill in your values

# Spotify API
SPOTIFY_CLIENT_ID=your_client_id
SPOTIFY_CLIENT_SECRET=your_client_secret
SPOTIFY_TOKEN_FILE=~/.percy/credentials/spotify-tokens.json

# Philips Hue
HUE_BASE=http://your-hue-bridge-ip/api/your-api-key
HUE_GROUPS={"1": "Living Room", "2": "Bedroom"}

# Ollama (local LLM server)
OLLAMA_HOST=http://your-ollama-host:11434
OLLAMA_HOST_IP=your-ollama-host-ip

# Yamaha MusicCast receiver
YAMAHA_BASE=http://your-yamaha-ip/YamahaExtendedControl/v1

# SSH targets
NAS_SSH_TARGET=user@your-nas-ip
REMOTE_HOST_SSH=user@your-remote-host-ip

# Network
LAN_IP=your-host-lan-ip

# Log file paths
BACKUP_LOG=~/.percy/logs/backup.log
BULLETIN_PREP_LOG=~/.percy/logs/bulletin-prep.log
BULLETIN_SEND_LOG=~/.percy/logs/bulletin-send.log
REMOTE_DRAFT_LOG=C:\path\to\draft.log
