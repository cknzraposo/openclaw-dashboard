# OpenClaw Dashboard secrets only
# Copy to .env and fill in values. Non-secret settings live at the top of app.py.

# Spotify OAuth app credentials (used for token refresh requests).
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# Philips Hue API key (the bridge username/token).
HUE_API_KEY=your_hue_api_key

# SSH credentials/targets used for NAS and remote host panels.
# Format: user@hostname-or-ip
NAS_SSH_TARGET=user@nas-ip
REMOTE_HOST_SSH=user@remote-host-ip
